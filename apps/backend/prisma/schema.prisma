// apps/backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
  CLIENT
}

enum CompanyRole {
  OWNER      // Propriétaire qui paie le plan
  ADMIN      // Administrateur
  MEMBER     // Membre simple
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum Currency {
  EUR
  USD
  MGA
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ==================== USER & COMPANY ====================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  isActive          Boolean  @default(true)
  lastLogin         DateTime?
  role              UserRole @default(EMPLOYEE)
  permissions       Json? 
  
  // PLAN D'ABONNEMENT (porté par l'utilisateur s'il est propriétaire)
  // S'applique à TOUTES les companies dont il est propriétaire
  currentPlan        SubscriptionPlan?   @default(STARTER)
  subscriptionStatus SubscriptionStatus? @default(TRIAL)
  
  // Limites du plan
  maxUsers           Int?                @default(5)
  maxArticles        Int?                @default(1000)
  maxInvoices        Int?                @default(1000)
  maxStorage         Int?                @default(5) // en Go
  
  // Préférences
  defaultCompanyId  String?  // Company par défaut au login
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  ownedCompanies    Company[]        @relation("CompanyOwner")
  companyMemberships CompanyMember[]
  subscriptions     Subscription[]
  payments          Payment[]
  
  // Activités
  invoices          Invoice[]
  stockMovements    StockMovement[]
  presences         Presence[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  auditLogs         AuditLog[]
  notifications     Notification[]

  @@index([email])
  @@index([currentPlan])
  @@index([subscriptionStatus])
}

model Company {
  id                 String    @id @default(uuid())
  name               String
  email              String    @unique
  phone              String?
  address            String?
  taxId              String?
  logo               String?
  
  // Propriétaire de cette company (celui qui porte le plan)
  ownerId            String
  
  theme              Json?
  settings           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Le propriétaire porte le plan
  owner              User              @relation("CompanyOwner", fields: [ownerId], references: [id])
  
  // Relations
  members            CompanyMember[]
  articles           Article[]
  categories         Category[]
  clients            Client[]
  suppliers          Supplier[]
  invoices           Invoice[]
  warehouses         Warehouse[]
  transactions       Transaction[]
  payrolls           Payroll[]
  presences          Presence[]
  notifications      Notification[]
  messages           Message[]
  debts              Debt[]

  @@index([email])
  @@index([ownerId])
}

// Table de liaison User <-> Company (many-to-many)
model CompanyMember {
  id        String      @id @default(uuid())
  userId    String
  companyId String
  role      CompanyRole @default(MEMBER)
  
  // Permissions spécifiques dans cette company
  permissions Json?
  
  // Informations RH (spécifiques à cette company)
  position    String?
  salary      Decimal?  @db.Decimal(12, 2)
  hireDate    DateTime?
  
  // Statut
  isActive    Boolean   @default(true)
  invitedBy   String?   // ID de l'utilisateur qui l'a invité
  invitedAt   DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([role])
}

// ==================== SUBSCRIPTION SYSTEM ====================

// L'abonnement est lié à l'utilisateur (owner), pas à la company
model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             // L'owner qui paie
  plan                   SubscriptionPlan
  status                 SubscriptionStatus @default(TRIAL)
  
  // Dates
  startDate              DateTime           @default(now())
  endDate                DateTime?
  trialEndDate           DateTime?
  cancelledAt            DateTime?
  nextBillingDate        DateTime?
  
  // Billing
  billingPeriod          String             // monthly, yearly
  amount                 Decimal            @db.Decimal(10, 2)
  currency               Currency           @default(EUR)
  
  // Payment Integration (Stripe, etc.)
  stripeCustomerId       String?
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripePaymentMethodId  String?
  
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments               Payment[]

  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
}

model PlanFeature {
  id          String           @id @default(uuid())
  plan        SubscriptionPlan
  featureKey  String           // ex: "max_users", "advanced_analytics", "api_access"
  featureName String           // ex: "Jusqu'à 25 utilisateurs"
  enabled     Boolean          @default(true)
  limit       Int?             // null = illimité
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([plan, featureKey])
  @@index([plan])
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String        // L'owner qui paie
  subscriptionId        String?
  amount                Decimal       @db.Decimal(10, 2)
  currency              Currency      @default(EUR)
  status                PaymentStatus @default(PENDING)
  paymentMethod         String?       // card, bank_transfer, mobile_money, paypal
  
  // Stripe Integration
  stripePaymentIntentId String?       @unique
  stripeInvoiceId       String?       @unique
  stripeChargeId        String?
  
  description           String?
  receiptUrl            String?
  failureReason         String?
  metadata              Json?
  
  paidAt                DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription          Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([stripePaymentIntentId])
}

// ==================== INVENTORY & CATALOG ====================

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  parentId    String?
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  articles    Article[]

  @@index([companyId])
  @@index([parentId])
}

model Article {
  id            String   @id @default(uuid())
  code          String
  name          String
  description   String?
  purchasePrice Decimal  @db.Decimal(12, 2)
  sellingPrice  Decimal  @db.Decimal(12, 2)
  stockMin      Int      @default(0)
  stockMax      Int?
  currentStock  Int      @default(0)
  unit          String?
  barcode       String?
  image         String?
  categoryId    String?
  supplierId    String?
  companyId     String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category       Category?        @relation(fields: [categoryId], references: [id])
  supplier       Supplier?        @relation(fields: [supplierId], references: [id])
  invoiceItems   InvoiceItem[]
  stockMovements StockMovement[]
  warehouseStock WarehouseStock[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([barcode])
}

// ==================== PARTNERS ====================

model Client {
  id          String    @id @default(uuid())
  code        String
  name        String
  email       String?
  phone       String?
  address     String?
  taxId       String?
  creditLimit Decimal?  @db.Decimal(12, 2)
  companyId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  debts       Debt[]    @relation("ClientDebts")

  @@unique([code, companyId])
  @@index([companyId])
  @@index([email])
}

model Supplier {
  id          String    @id @default(uuid())
  code        String
  name        String
  email       String?
  phone       String?
  address     String?
  taxId       String?
  companyId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  articles    Article[]
  debts       Debt[]    @relation("SupplierDebts")

  @@unique([code, companyId])
  @@index([companyId])
  @@index([email])
}

// ==================== INVOICING ====================

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String
  clientId      String
  userId        String
  companyId     String
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(5, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  notes         String?
  dueDate       DateTime?
  paidDate      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  items         InvoiceItem[]
  transactions  Transaction[]

  @@unique([invoiceNumber, companyId])
  @@index([companyId])
  @@index([clientId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id         String  @id @default(uuid())
  invoiceId  String
  articleId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  discount   Decimal @default(0) @db.Decimal(5, 2)
  total      Decimal @db.Decimal(12, 2)

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  article    Article @relation(fields: [articleId], references: [id])

  @@index([invoiceId])
  @@index([articleId])
}

// ==================== WAREHOUSE & STOCK ====================

model Warehouse {
  id          String   @id @default(uuid())
  name        String
  address     String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]
  warehouseStocks WarehouseStock[]

  @@index([companyId])
}

model WarehouseStock {
  id          String   @id @default(uuid())
  warehouseId String
  articleId   String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, articleId])
  @@index([warehouseId])
  @@index([articleId])
}

model StockMovement {
  id          String   @id @default(uuid())
  articleId   String
  warehouseId String
  userId      String
  quantity    Int
  type        String   // IN, OUT, ADJUSTMENT, TRANSFER
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())

  article     Article   @relation(fields: [articleId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([articleId])
  @@index([warehouseId])
  @@index([userId])
  @@index([createdAt])
}

// ==================== ACCOUNTING ====================

model Transaction {
  id          String          @id @default(uuid())
  companyId   String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String
  category    String?
  invoiceId   String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([companyId])
  @@index([type])
  @@index([date])
  @@index([invoiceId])
}

model Debt {
  id          String   @id @default(uuid())
  companyId   String
  clientId    String?
  supplierId  String?
  amount      Decimal  @db.Decimal(12, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(12, 2)
  dueDate     DateTime
  description String
  status      String   @default("PENDING") // PENDING, PARTIAL, PAID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client      Client?   @relation("ClientDebts", fields: [clientId], references: [id])
  supplier    Supplier? @relation("SupplierDebts", fields: [supplierId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
}

// ==================== HR & PAYROLL ====================

model Payroll {
  id           String    @id @default(uuid())
  companyId    String
  employeeId   String
  period       String    // ex: "2024-01", "2024-Q1"
  baseSalary   Decimal   @db.Decimal(12, 2)
  bonuses      Decimal   @default(0) @db.Decimal(12, 2)
  deductions   Decimal   @default(0) @db.Decimal(12, 2)
  netSalary    Decimal   @db.Decimal(12, 2)
  paidDate     DateTime?
  createdAt    DateTime  @default(now())

  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([period])
}

model Presence {
  id         String    @id @default(uuid())
  userId     String
  companyId  String
  date       DateTime
  checkIn    DateTime
  checkOut   DateTime?
  status     String    @default("PRESENT") // PRESENT, ABSENT, LATE, HALF_DAY
  notes      String?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id])
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([date])
}

// ==================== COMMUNICATION ====================

model Notification {
  id         String   @id @default(uuid())
  companyId  String
  userId     String?
  type       String   // INFO, WARNING, ERROR, SUCCESS
  title      String
  message    String
  data       Json?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Message {
  id         String   @id @default(uuid())
  companyId  String
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([companyId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== AUDIT ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity     String   // User, Invoice, Article, etc.
  entityId   String
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}